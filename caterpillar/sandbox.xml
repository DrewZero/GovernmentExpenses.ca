<?xml version="1.0" encoding="utf-8" ?>

<CATERPILLAR>

	<!-- This is the database to use for our repository -->
	<DATABASE NAME="TRAVELDB" CONNECTIONSTRING="Data Source=bine.ca;Database=metamorph;uid=caterpillar;pwd=metamorphosis" TABLE="sandbox_travel"></DATABASE>
	<DATABASE NAME="HOSPITALITYDB" CONNECTIONSTRING="Data Source=bine.ca;Database=metamorph;uid=caterpillar;pwd=metamorphosis" TABLE="sandbox_hospitality"></DATABASE>

	
	<!-- Each RECORDTYPE entry specifies a record structure which is to be scraped from the web and inserted into a database -->

	<RECORDTYPE NAME="TRAVEL">
		<PARAMETER NAME="member" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="purpose" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="date_from" TYPE="DateParameter"></PARAMETER>
		<PARAMETER NAME="date_to" TYPE="DateParameter"></PARAMETER>
		<PARAMETER NAME="destination" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="commercial_flight" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="chartered_flight" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="government_aircraft" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="other_transportation" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="accommodation" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="meals_incidentals" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="other" TYPE="DecimalParameter"></PARAMETER>
		<PARAMETER NAME="total" TYPE="DecimalParameter"></PARAMETER>
	</RECORDTYPE>
	
	<RECORDTYPE NAME="HOSPITALITY">
		<PARAMETER NAME="member" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="description" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="date_from" TYPE="DateParameter"></PARAMETER>
		<PARAMETER NAME="employees" TYPE="IntParameter"></PARAMETER>
		<PARAMETER NAME="guests" TYPE="IntParameter"></PARAMETER>
		<PARAMETER NAME="location" TYPE="StringParameter"></PARAMETER>
		<PARAMETER NAME="total" TYPE="DecimalParameter"></PARAMETER>
	</RECORDTYPE>

	
	<REGEX NAME="URL" REGEX="&lt;A\s+[^&gt;]*HREF\s*=\s*('(?'URL'[^&gt;']+)'|&quot;(?'URL'[^&gt;&quot;]+)&quot;|(?'URL'[^&gt;\s]+))[^&gt;]*&gt;"></REGEX>
	<REGEX NAME="TRAVEL" REGEX="&lt;strong&gt;Travel Expense&lt;/strong&gt;(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'member'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'purpose'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;\s*(?'date_from'[^\s]+)\s+to\s+(?'date_to'[^\s&lt;]+)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'destination'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'commercial_flight'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'other_transportation'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'accommodation'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'meals_incidentals'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'other'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'total'[^&lt;]*)"></REGEX>
	<!-- TODO - add the format for the full travel data, including chartered_flight and government_aircraft -->
	<REGEX NAME="TRAVEL_FULL" REGEX="&lt;strong&gt;Travel Expense&lt;/strong&gt;(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'member'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'purpose'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;\s*(?'date_from'[^\s]+)\s+to\s+(?'date_to'[^\s&lt;]+)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'destination'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'commercial_flight'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'other_transportation'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'accommodation'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'meals_incidentals'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'other'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'total'[^&lt;]*)"></REGEX>
	<REGEX NAME="HOSPITALITY" REGEX="&lt;strong&gt;Hospitality Expense&lt;/strong&gt;(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'member'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'description'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'date_from'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;([^\d]*(?'employees'\d+)[^\d]+(?'guests'\d*)[^\d])?(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'location'[^&lt;]*)(?>.*?&lt;td)(?>.*?&lt;td).*?&gt;(?'total'[^&lt;]*)"></REGEX>


	<!-- URLTYPE encapsulates a type of root page including all sub pages and records -->
	<URLTYPE NAME="THREELEVEL">
		<!-- Each URLLIST entry specifies a page which contains links to other pages, which will be recursed -->
		<!-- NOTE: REGEX in a URLLIST must contain named parameter URL -->
		<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
			<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
				<URLLIST REGEX="URL" PREFIX="&lt;strong&gt;Travel Expenses" SUFFIX="/table">
					<!-- Each RECORDLIST entry specifies a page which contains one or more records to be acquired -->
					<!-- NOTE: REGEX in a RECORDLIST must contain named parameters for each paramname in specified RECORDTYPE -->
					<RECORDLIST REGEX="TRAVEL" RECORDTYPE="TRAVEL" DATABASE="TRAVELDB" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
					</RECORDLIST>
				</URLLIST>
				<URLLIST REGEX="URL" PREFIX="&lt;strong&gt;Hospitality Expenses" SUFFIX="/table">
					<RECORDLIST REGEX="HOSPITALITY" RECORDTYPE="HOSPITALITY" DATABASE="HOSPITALITYDB" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
					</RECORDLIST>
				</URLLIST>
			</URLLIST>
		</URLLIST>
	</URLTYPE>

	<URLTYPE NAME="FIVELEVEL">
		<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
			<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
				<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
					<URLLIST REGEX="URL" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
						<URLLIST REGEX="URL" PREFIX="&lt;strong&gt;Travel Expenses" SUFFIX="/table">
							<RECORDLIST REGEX="TRAVEL" RECORDTYPE="TRAVEL" DATABASE="TRAVELDB" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
							</RECORDLIST>
						</URLLIST>
						<URLLIST REGEX="URL" PREFIX="&lt;strong&gt;Hospitality Expenses" SUFFIX="/table">
							<RECORDLIST REGEX="HOSPITALITY" RECORDTYPE="HOSPITALITY" DATABASE="HOSPITALITYDB" PREFIX="CONTENT BEGINS" SUFFIX="CONTENT ENDS">
							</RECORDLIST>
						</URLLIST>
					</URLLIST>
				</URLLIST>
			</URLLIST>
		</URLLIST>
	</URLTYPE>


