	<URLTYPE NAME="TEST_HOSPITALITY_FOREIGN_AFFAIRS">
		<RECORDLIST REGEX="HOSPITALITY_FOREIGN_AFFAIRS" RECORDTYPE="HOSPITALITY" DATABASE="HOSPITALITYDB" PREFIX="CONTENT REUSE BEGINS" SUFFIX="CONTENT REUSE ENDS" DATEFORMAT="dd/MM/yyyy">
