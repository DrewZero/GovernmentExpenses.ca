	<ROOTPAGE URLTYPE="TEST_HOSPITALITY_FOREIGN_AFFAIRS" URL="http://w01.international.gc.ca/dthe-dfva/Detail.aspx?lang=eng&amp;dept=faae&amp;prof_id=297&amp;ya=2009&amp;ed_id=24422&amp;type=ha"></ROOTPAGE>
